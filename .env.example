# ========== BANCO DE DADOS (PlanetScale ou Railway MySQL) ==========
DATABASE_URL=mysql://USUARIO:SENHA@HOST:3306/reabilite

# ========== SEGURANÇA ==========
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=GERE_UMA_CHAVE_AQUI_MIN_32_CHARS

# ========== ADMIN ==========
# openId do seu usuário admin (preencha após primeiro cadastro, veja no DB)
OWNER_OPEN_ID=local_SEU_OPEN_ID_AQUI
OWNER_NAME=Luan de Oliveira Pereira

# ========== PORTA (opcional) ==========
PORT=3000
